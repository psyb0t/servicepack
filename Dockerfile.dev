# Example user Dockerfile.dev
# This file demonstrates how to override the framework development image
# Delete this file to use the default framework image (Dockerfile.servicepack.dev)

FROM golang:1.26-alpine

# Install build dependencies
RUN apk add --no-cache \
    make \
    gcc \
    musl-dev \
    bash

# Set working directory
WORKDIR /app

# Copy source code
COPY . .

# Set env vars
ENV ENV=dev
ENV LOG_LEVEL=debug
ENV LOG_FORMAT=text
ENV LOG_ADD_SOURCE=true
ENV SERVICES_ENABLED=

# Default command - shows available make targets
CMD ["make", "help"]